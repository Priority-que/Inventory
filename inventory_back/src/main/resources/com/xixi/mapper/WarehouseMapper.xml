<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xixi.mapper.WarehouseMapper">
    <select id="getWarehousePage" resultType="com.xixi.pojo.vo.warehouse.WarehousePageVO">
        select * from warehouse
        <where>
            <if test="q.code != null and q.code != ''">
                and code like concat('%',#{q.code},'%')
            </if>
            <if test="q.name != null and q.code !=  ''">
                and name like concat('%',#{q.name},'%')
            </if>
            <if test="q.address !=null and q.address != ''">
                and address like concat('%',#{q.address},'%')
            </if>
            <if test="q.managerName !=null and q.managerName != ''">
                and manager_name like concat('%',#{q.managerName},'%')
            </if>
            <if test="q.status !=null and q.status != ' '">
                and status like concat('%',#{q.status},'%')
            </if>
        </where>
    </select>
</mapper>