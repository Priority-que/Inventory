APP_NAME=inventory-python-workflow-service
APP_ENV=dev

JAVA_BACKEND_BASE_URL=http://localhost:8080
JAVA_BACKEND_TIMEOUT=10

AI_DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
MODEL_API_KEY=
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus
MODEL_TIMEOUT=30

RAG_EMBEDDING_MODEL=text-embedding-v3
RAG_EMBEDDING_TIMEOUT=30
RAG_INDEX_NAME=inventory:rag:index
RAG_KEY_PREFIX=inventory:rag:chunk:
RAG_DEFAULT_TOP_K=4
RAG_MAX_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.35

REDIS_HOST=114.132.43.247
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-mysql-password
MYSQL_DATABASE=inventory
MYSQL_CHARSET=utf8mb4
